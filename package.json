{
  "name": "shelby-feed-protocol",
  "version": "0.1.0",
  "description": "Real-time data feed protocol built on Shelby — chunk any stream into blobs, index them, and serve AI subscribers at low latency",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev:writer": "tsx watch src/writer/server.ts",
    "dev:index": "tsx watch src/index/server.ts",
    "start:writer": "node dist/writer/server.js",
    "start:index": "node dist/index/server.js",
    "simulate": "tsx scripts/simulate-producer.ts"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^6.0.0",
    "@shelby-protocol/sdk": "latest",
    "dotenv": "^16.4.5",
    "hono": "^4.4.0",
    "@hono/node-server": "^1.12.0",
    "ioredis": "^5.3.2",
    "pg": "^8.12.0",
    "zod": "^3.23.8",
    "nanoid": "^5.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2"
  }
}
