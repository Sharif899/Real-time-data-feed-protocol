# ── Aptos / Shelby ────────────────────────────────────────────────
APTOS_PRIVATE_KEY=ed25519-priv-0x...
APTOS_NETWORK=testnet
SHELBY_API_KEY=aptoslabs_***
SHELBY_RPC_URL=https://api.testnet.shelby.xyz

# ── Postgres (chunk index) ─────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/shelby_feed

# ── Redis (pub/sub + window buffer) ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Chunk writer settings ─────────────────────────────────────────
# How many seconds of events to collect before flushing a blob
CHUNK_WINDOW_SECONDS=5
# How long to keep blobs alive on Shelby (days)
BLOB_TTL_DAYS=7

# ── Ports ────────────────────────────────────────────────────────
WRITER_PORT=3100
INDEX_PORT=3101
